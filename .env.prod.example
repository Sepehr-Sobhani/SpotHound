# Copy to .env.prod on the server and fill in. Gitignored.

# Backend connects to the bundled Postgres service (host = db).
DATABASE_URL=postgresql+psycopg2://spothound:spothound@db:5432/spothound
POSTGRES_PASSWORD=spothound        # set a strong value; must match DATABASE_URL

# Strong random secret: generate with `openssl rand -base64 48`
JWT_SECRET=change-me

HEADLESS=true

# Admin account created on first deploy by deploy.sh
ADMIN_USERNAME=seso
ADMIN_PASSWORD=change-me

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Caddy site address. ":80" = plain HTTP on the server IP. Set to a domain you
# point at the server (e.g. spothound.example.com) for automatic HTTPS.
SITE_ADDRESS=:80
