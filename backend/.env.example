# Copy to .env and fill in. pydantic-settings reads these (case-insensitive).
DATABASE_URL=postgresql+psycopg2://spothound:spothound@localhost:5432/spothound
JWT_SECRET=change-me
HEADLESS=true

# Admin account created by `uv run python -m app.seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# From @BotFather; leave blank to log notifications to the console instead
TELEGRAM_BOT_TOKEN=
